{
  "name": "eslint-plugin-lodash-specific-import",
  "version": "2.0.0-alpha.0",
  "description": "An ESLint plugin to enforce specific lodash imports, preventing global or named imports from 'lodash'.",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin"
  ],
  "author": "Darshan Jain <djainj86@gmail.com>",
  "files": [
    "lib",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "main": "./lib/index.js",
  "exports": {
    ".": {
      "require": "./lib/index.js",
      "import": "./lib/index.mjs",
      "default": "./lib/index.js"
    }
  },
  "scripts": {
    "check:docs": "npm run lint:eslint-docs",
    "check:pack": "npm pack --dry-run --cache /tmp/eslint-plugin-lodash-specific-import-npm-cache > /dev/null",
    "lint": "npm-run-all \"lint:*\"",
    "lint:eslint-docs": "npm-run-all \"update:eslint-docs --check \"",
    "lint:js": "eslint . --ignore-pattern \"tests/fixtures/**\"",
    "test": "mocha tests/lib --recursive",
    "update:eslint-docs": "eslint-doc-generator"
  },
  "dependencies": {
    "requireindex": "^1.2.0"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^10.0.0",
    "eslint-doc-generator": "^1.0.0",
    "eslint-plugin-eslint-plugin": "^5.0.0",
    "eslint-plugin-node": "^11.1.0",
    "mocha": "^10.0.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "eslint": "^8.0.0 || ^9.0.0 || ^10.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darshan09200/eslint-plugin-lodash-specific-import.git"
  },
  "bugs": {
    "url": "https://github.com/darshan09200/eslint-plugin-lodash-specific-import/issues"
  },
  "homepage": "https://github.com/darshan09200/eslint-plugin-lodash-specific-import#readme"
}
